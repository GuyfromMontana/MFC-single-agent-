# Montana Feed Company Voice Agent — Environment Variables
# Copy this file to `.env` and fill in your values.
# Never commit .env to git.

# -----------------------------------------------------------------------------
# Supabase (database + conversation storage)
# Dashboard: https://supabase.com/dashboard → Project → Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
# Used by the Python runtime (main.py, config.py). Safe to use service role here
# since this runs server-side only.
SUPABASE_KEY=your-service-role-key-here
# Used ONLY by regenerate-embeddings.js / backfill_embeddings.py.
# This is the SAME value as SUPABASE_KEY above — the one-off scripts just
# use the Supabase-standard variable name for the service-role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Zep (long-term memory for callers)
# Dashboard: https://app.getzep.com
# -----------------------------------------------------------------------------
ZEP_API_KEY=your-zep-api-key-here

# -----------------------------------------------------------------------------
# OpenAI (embeddings)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here

# -----------------------------------------------------------------------------
# Retell (voice agent platform)
# REQUIRED for webhook signature verification.
# Dashboard: https://dashboard.retellai.com → Settings → API Keys
# -----------------------------------------------------------------------------
RETELL_API_KEY=your-retell-api-key-here
# Signature enforcement. Fail-safe: any value outside the disable set (below)
# is treated as ENFORCE. Disable values (case-insensitive): false, 0, no, off.
# Use an explicit disable value only for local dev without a real Retell signature.
RETELL_SIGNATURE_ENFORCE=true

# -----------------------------------------------------------------------------
# Resend (transactional email to specialists)
# Dashboard: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your-resend-key-here
FROM_EMAIL=notifications@axmen.com

# -----------------------------------------------------------------------------
# Admin endpoints (/fix-zep-user, /set-user-location)
# Clients must send header `X-Admin-Token: <this value>`. Generate with:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave unset to disable admin endpoints entirely (they'll return 403).
# -----------------------------------------------------------------------------
ADMIN_API_TOKEN=
